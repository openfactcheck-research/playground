# OpenFactCheck Playground — Environment Variables
#
# Vite loads the file matching --mode:
#   pnpm dev                        → .env (local API + auth bypass)
#   pnpm dev --mode devhasan        → .env.devhasan (devhasan cloud API + Cognito)
#   pnpm dev --mode integration     → .env.integration
#   pnpm dev --mode production      → .env.production
#
# Copy this file to .env and fill in values for local development.

# API base URL (required)
VITE_API_URL=http://localhost:8000

# Auth bypass — skip Cognito login, API must also run with auth bypass
# Only used for local development
VITE_AUTH_BYPASS=true

# AWS Cognito — required for cloud environments, not needed when auth is bypassed
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
